apiVersion: v1
kind: ConfigMap
metadata:
  name: {{_passdb_cm.name}}
  namespace: {{_pod_namespace}}
  labels:
    app: {{_pod_name}}
    configurator: ansible
  annotations:
    ansible.run-id: "{{ansible_run_id|default('N/A')}}"
    ansible.config_file: "{{ansible_config_file|default('N/A')}}"
    ansible.version: "{{ansible_version.full}}"
data:
{% if _passdb_cm.passdb is string %}
  {{_passdb_cm.passdb | basename}}: |
{{ lookup(k3s_passdb, _passdb_cm.passdb, returnall=true) | indent(4, first=True) }}
{% else %}
{% for path in _passdb_cm.passdb %}
  {{path | basename}}: |
{{ lookup(k3s_passdb, path, returnall=true) | indent(4, first=True) }}
{% endfor %}
{% endif %}
